{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Doktori",
  "version": "0.1.0",
  "identifier": "tn.doktori.desktop",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "windows": [
      {
        "title": "Doktori",
        "width": 1280,
        "height": 840,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "url": "http://localhost:3000/app-picker"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Medical",
    "shortDescription": "Portail Doktori (médecin + secrétaire)",
    "longDescription": "Application desktop pour médecins et secrétaires du réseau Doktori. Appels audio, messagerie, agenda, notifications OS."
  }
}
