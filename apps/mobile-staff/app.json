{
  "expo": {
    "name": "Doktori Pro",
    "slug": "doktori-staff",
    "scheme": "doktori-pro",
    "version": "0.1.0",
    "updates": {
      "enabled": false
    },
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "cover",
      "backgroundColor": "#0E7490"
    },
    "notification": {
      "icon": "./assets/notification-icon.png",
      "color": "#0891B2",
      "androidMode": "default",
      "androidCollapsedTitle": "Doktori Pro"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "tn.doktori.staff",
      "infoPlist": {
        "NSCameraUsageDescription": "Caméra utilisée pour les téléconsultations patient.",
        "NSMicrophoneUsageDescription": "Micro utilisé pour les téléconsultations patient.",
        "NSFaceIDUsageDescription": "Utiliser Face ID pour déverrouiller Doktori Pro.",
        "UIBackgroundModes": ["voip", "remote-notification"]
      }
    },
    "android": {
      "package": "tn.doktori.staff",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0E7490"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.VIBRATE",
        "android.permission.RECEIVE_BOOT_COMPLETED"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "color": "#0891B2",
          "defaultChannel": "default",
          "sounds": []
        }
      ],
      "expo-local-authentication",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiBaseUrl": "https://doktori.tn"
    }
  }
}
